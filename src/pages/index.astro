---
import BaseLayout from '../layouts/BaseLayout.astro';
import CopyEmail from '../components/CopyEmail.tsx';
import { site } from '../config/site';

const linkClass =
  'text-neutral-300 underline-offset-4 transition-colors hover:text-neutral-50 hover:underline';
---

<BaseLayout title={site.name}>
  <main class="mx-auto flex min-h-screen max-w-2xl flex-col justify-center px-6 py-16">
    <p class="mb-3 text-xs font-medium uppercase tracking-widest text-neutral-500">
      Placeholder — v1 scaffold
    </p>
    <h1 class="text-4xl font-semibold tracking-tight sm:text-5xl">{site.name}</h1>
    <p class="mt-4 text-lg text-neutral-400">{site.tagline}</p>

    <nav class="mt-8 flex flex-wrap items-center gap-x-6 gap-y-3 text-sm" aria-label="Contact">
      <a class={linkClass} href={`mailto:${site.email}`}>Email</a>
      <a class={linkClass} href={site.links.linkedin} rel="me noopener" target="_blank">
        LinkedIn
      </a>
      <a class={linkClass} href={site.links.github} rel="me noopener" target="_blank">
        GitHub
      </a>
    </nav>

    <div class="mt-8">
      <CopyEmail email={site.email} client:load />
    </div>

    <p class="mt-12 text-xs text-neutral-600">
      All copy, links, and contact details on this page are placeholders. Real content ships in a
      later spec.
    </p>
  </main>
</BaseLayout>
